# Browser-safe Supabase configuration. Never place the service-role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Optional locally. Staging and production require a separate public site key.
VITE_TURNSTILE_SITE_KEY=replace-with-local-turnstile-site-key
