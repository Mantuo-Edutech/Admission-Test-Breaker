{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mantuo.org/schemas/tmua/question-revision.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "revision",
    "exam",
    "paperId",
    "edition",
    "paper",
    "questionNumber",
    "sourceType",
    "contentStage",
    "reviewStatus",
    "sourcePage",
    "stem",
    "options",
    "correctAnswer",
    "solution",
    "sourceRefs",
    "knowledgeTags",
    "skillTags",
    "errorTypes",
    "extraction"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^tmua-.+-p[12]-q(0[1-9]|1[0-9]|20)$" },
    "revision": { "const": 1 },
    "exam": { "const": "TMUA" },
    "paperId": { "type": "string", "pattern": "^tmua-.+-p[12]$" },
    "edition": { "type": "string", "minLength": 1 },
    "paper": { "enum": [1, 2] },
    "questionNumber": { "type": "integer", "minimum": 1, "maximum": 20 },
    "sourceType": { "const": "past_paper" },
    "contentStage": { "const": "extracted" },
    "reviewStatus": { "const": "needs_review" },
    "sourcePage": {
      "type": "object",
      "required": ["format", "rawText"],
      "properties": {
        "format": { "const": "pdf-layout-text" },
        "rawText": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "stem": {
      "type": "object",
      "required": ["format", "rawText"],
      "properties": {
        "format": { "const": "pdf-layout-text" },
        "rawText": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["label", "rawText"],
        "properties": {
          "label": { "type": "string", "pattern": "^[A-H]$" },
          "rawText": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "correctAnswer": { "type": "string", "pattern": "^[A-H]$" },
    "solution": {
      "type": "object",
      "required": ["format", "rawText"],
      "properties": {
        "format": { "const": "pdf-layout-text" },
        "rawText": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["role", "sourceId", "portablePath", "sha256", "pages"],
        "properties": {
          "role": { "enum": ["question", "answer_key", "worked_solution"] },
          "sourceId": { "type": "string", "minLength": 1 },
          "portablePath": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
          },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "pages": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 1 },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "knowledgeTags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "skillTags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "errorTypes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "extraction": {
      "type": "object",
      "required": ["generatedAt", "generatedBy", "method", "mathFidelity", "warnings"],
      "properties": {
        "generatedAt": { "type": "string", "format": "date-time" },
        "generatedBy": { "const": "tmua-extraction-cli" },
        "method": { "const": "poppler-layout-text" },
        "mathFidelity": { "const": "needs_review" },
        "warnings": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
