        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "What is the value of" }, { "kind": "math", "tex": "x^3+\\frac{1}{x^3}" }, { "kind": "text", "value": "?" }] }
      ],
      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "math", "tex": "12" }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "math", "tex": "15" }] }] },
