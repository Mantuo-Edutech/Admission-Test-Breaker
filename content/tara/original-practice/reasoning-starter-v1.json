        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Tuesday" }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "It cannot be determined" }] }] }
      ],
      "correctAnswer": "C",
