      "prompt": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Four talks, A, B, C and D, are scheduled one after another. A is before B. C is immediately after A. D is last. Which order is possible?" }] }
      ],
      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "A, B, C, D" }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "A, C, B, D" }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "B, A, C, D" }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "C, A, B, D" }] }] }
      ],
      "correctAnswer": "B",
      "knowledgeTags": ["tara-problem-ordering"],
      "skillTags": ["ordering", "constraint-satisfaction"],
      "reviewStatus": "verified",
