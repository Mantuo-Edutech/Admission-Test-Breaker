  "questions": [
    {
      "id": "tara-reasoning-starter-v1-q01",
      "number": 1,
      "sourcePage": 1,
      "prompt": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "A town park currently closes at 7 pm. A three-month pilot kept it open until 10 pm. During the pilot, evening visitor numbers rose substantially, while reported incidents did not increase. The lit paths were already maintained overnight, so the extra staffing cost was modest. The council should therefore make the later closing time permanent." }] },
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Which option states the main conclusion of the argument?" }] }
      ],
      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The park's paths are lit overnight." }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Evening visitor numbers rose during the pilot." }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The extra staffing cost was modest." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The council should permanently close the park at 10 pm." }] }] }
      ],
      "correctAnswer": "D",
      "knowledgeTags": ["tara-critical-main-conclusion"],
      "skillTags": ["argument-structure", "main-conclusion"],
      "reviewStatus": "verified",
      "sourceQuestionPath": "content/tara/original-practice/reasoning-starter-v1.json",
      "sourceAnswerPath": "content/tara/original-practice/reasoning-starter-v1.json"
    },
    {
      "id": "tara-reasoning-starter-v1-q02",
      "number": 2,
      "sourcePage": 2,
      "prompt": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "A university lecturer argues: ‘All lectures should be recorded. Students who miss a class could then watch it later, so recording lectures would improve their opportunity to learn the missed material.’" }] },
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Which assumption is required by this argument?" }] }
      ],
      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Every student prefers recordings to live lectures." }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "At least some students who miss class would be able and willing to use the recording." }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Recorded lectures never contain technical problems." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Attendance at live lectures would remain unchanged." }] }] }
      ],
      "correctAnswer": "B",
      "knowledgeTags": ["tara-critical-assumption"],
      "skillTags": ["necessary-assumption", "argument-gap"],
      "reviewStatus": "verified",
      "sourceQuestionPath": "content/tara/original-practice/reasoning-starter-v1.json",
      "sourceAnswerPath": "content/tara/original-practice/reasoning-starter-v1.json"
    },
    {
      "id": "tara-reasoning-starter-v1-q03",
      "number": 3,
      "sourcePage": 3,
      "prompt": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Schools with debate clubs report higher levels of civic participation among former pupils. Therefore, if every school creates a debate club, civic participation will necessarily rise." }] },
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "What is the principal flaw in this reasoning?" }] }
      ],
      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "It assumes that civic participation can never be measured." }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "It gives too much detail about former pupils." }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "It treats an association as proof that the debate club caused the difference." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "It concludes that debate should be removed from schools." }] }] }
      ],
      "correctAnswer": "C",
      "knowledgeTags": ["tara-critical-flaw"],
      "skillTags": ["correlation-causation", "evaluation"],
      "reviewStatus": "verified",
      "sourceQuestionPath": "content/tara/original-practice/reasoning-starter-v1.json",
      "sourceAnswerPath": "content/tara/original-practice/reasoning-starter-v1.json"
    },
    {
      "id": "tara-reasoning-starter-v1-q04",
      "number": 4,
      "sourcePage": 4,
      "prompt": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "A college plans to replace printed handbooks with digital copies, arguing that this will reduce the environmental impact of producing and distributing the handbooks." }] },
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Which finding would most strengthen the argument?" }] }
      ],
      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Almost all students already own a suitable device, and producing the printed handbooks creates substantially more emissions than storing and downloading the files." }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Some students like the smell of newly printed paper." }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The handbook's cover was redesigned last year." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Digital files can use several different fonts." }] }] }
      ],
      "correctAnswer": "A",
      "knowledgeTags": ["tara-critical-evidence"],
      "skillTags": ["strengthen-argument", "relevant-evidence"],
      "reviewStatus": "verified",
      "sourceQuestionPath": "content/tara/original-practice/reasoning-starter-v1.json",
      "sourceAnswerPath": "content/tara/original-practice/reasoning-starter-v1.json"
    },
    {
      "id": "tara-reasoning-starter-v1-q05",
      "number": 5,
      "sourcePage": 5,
      "prompt": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "All research fellows submit a report. No incomplete report is published. Arun is a research fellow, and Arun's report was published." }] },
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Which conclusion follows?" }] }
      ],
      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Every submitted report is published." }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Only research fellows write complete reports." }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Arun submitted more than one report." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Arun's published report was complete." }] }] }
      ],
      "correctAnswer": "D",
      "knowledgeTags": ["tara-critical-inference"],
      "skillTags": ["deduction", "necessary-conclusion"],
      "reviewStatus": "verified",
      "sourceQuestionPath": "content/tara/original-practice/reasoning-starter-v1.json",
