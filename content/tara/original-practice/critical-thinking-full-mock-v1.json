      ],
      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Every uncollected reservation is for a printed book." }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The library desk should never open later." }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "At least some students fail to collect reservations because the desk closes before they can arrive, and would use the lockers." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The lockers would hold every book in the library." }] }] },
        { "label": "E", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Students prefer lockers to speaking to library staff." }] }] }
      ],
      "correctAnswer": "C", "knowledgeTags": ["tara-critical-assumption"], "skillTags": ["identifying-assumption", "argument-gap"], "reviewStatus": "verified", "sourceQuestionPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json", "sourceAnswerPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json"
    },
    {
