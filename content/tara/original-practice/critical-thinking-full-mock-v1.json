    {
      "id": "tara-critical-thinking-full-mock-v1-q01", "number": 1, "sourcePage": 1,
      "prompt": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Many evening laboratory sessions finish after the last campus shuttle. Students then pay for taxis or walk along an unlit road. Extending the shuttle by one hour would require only one additional journey, and a trial journey was usually more than half full. The university should therefore extend the shuttle service during teaching weeks." }] },
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Which option best expresses the main conclusion?" }] }
      ],
      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Some laboratory sessions finish late." }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Students sometimes pay for taxis." }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The road beside the campus is unlit." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The university should extend the shuttle service during teaching weeks." }] }] },
        { "label": "E", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "A trial shuttle was usually more than half full." }] }] }
      ],
      "correctAnswer": "D", "knowledgeTags": ["tara-critical-main-conclusion"], "skillTags": ["identifying-main-conclusion"], "reviewStatus": "verified", "sourceQuestionPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json", "sourceAnswerPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json"
    },
    {
