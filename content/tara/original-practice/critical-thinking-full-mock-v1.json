      "prompt": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "A voluntary survey conducted at a city cycling festival found that 82% of respondents wanted more cycle lanes. The mayor concludes that 82% of all city residents want more cycle lanes." }] },
