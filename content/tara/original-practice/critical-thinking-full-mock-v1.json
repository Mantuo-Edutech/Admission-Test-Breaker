      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Disposable cups currently form most of the cafés' non-food waste, and a trial deposit scheme achieved high return rates." }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Some students buy drinks from cafés outside the college." }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The college cafés sell several kinds of tea." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Reusable cups are available in several colours." }] }] },
        { "label": "E", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The cafés changed coffee supplier last year." }] }] }
      ],
      "correctAnswer": "A", "knowledgeTags": ["tara-critical-evidence"], "skillTags": ["assessing-additional-evidence", "strengthen"], "reviewStatus": "verified", "sourceQuestionPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json", "sourceAnswerPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json"
    },
    {
