      "options": [
        { "label": "A", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Proposal H was not submitted this year." }] }] },
        { "label": "B", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Proposal H did not receive funding this year." }] }] },
        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Every proposal with a community partner received funding." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Proposal H was the only proposal without a partner." }] }] },
        { "label": "E", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "Community partners decide which proposals receive funding." }] }] }
      ],
      "correctAnswer": "B", "knowledgeTags": ["tara-critical-inference"], "skillTags": ["drawing-conclusion", "necessary-inference"], "reviewStatus": "verified", "sourceQuestionPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json", "sourceAnswerPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json"
    },
    {
      "id": "tara-critical-thinking-full-mock-v1-q03", "number": 3, "sourcePage": 3,
      "prompt": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "The library should install collection lockers outside the main entrance. Students who cannot reach the desk before it closes could collect reserved books later, so the lockers would reduce the number of reservations that are never collected." }] },
