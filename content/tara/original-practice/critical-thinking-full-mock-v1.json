        { "label": "C", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The survey gives an exact percentage." }] }] },
        { "label": "D", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "People attending a cycling festival are unlikely to be representative of all residents." }] }] },
        { "label": "E", "content": [{ "kind": "paragraph", "runs": [{ "kind": "text", "value": "The mayor does not say how many cycle lanes already exist." }] }] }
      ],
      "correctAnswer": "D", "knowledgeTags": ["tara-critical-flaw"], "skillTags": ["detecting-reasoning-errors", "selection-bias"], "reviewStatus": "verified", "sourceQuestionPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json", "sourceAnswerPath": "content/tara/original-practice/critical-thinking-full-mock-v1.json"
    },
    {
