    {
      "id": "clinic-activity",
      "title": "Clinic activity",
      "content": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "The table shows one day's booked appointments. Treat all percentages as exact." }] },
        {
          "kind": "table",
          "caption": "Booked appointments and consultation time",
          "headers": ["Clinic", "Booked", "No-show rate", "Average consultation"],
          "rows": [
            ["North", "160", "12.5%", "18 min"],
            ["Central", "180", "10%", "15 min"],
            ["West", "140", "5%", "20 min"]
          ]
        }
      ]
    },
    {
      "id": "pharmacy-stock",
      "title": "Pharmacy stock",
      "content": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "All quantities are packs. Closing stock equals opening stock plus packs received, minus packs issued and damaged." }] },
        {
          "kind": "table",
          "caption": "Weekly stock movement",
          "headers": ["Item", "Opening", "Received", "Issued", "Damaged"],
          "rows": [
            ["A", "480", "240", "515", "5"],
            ["B", "350", "180", "402", "8"],
            ["C", "625", "0", "540", "10"],
            ["D", "290", "330", "500", "20"]
          ]
        }
      ]
    },
    {
      "id": "mobile-clinic-routes",
      "title": "Mobile clinic routes",
      "content": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Distance is one way. Fuel cost applies to every kilometre of the round trip, while each toll is paid once for the complete round trip." }] },
        {
          "kind": "table",
          "caption": "Route distance, time and direct cost",
          "headers": ["Route", "One-way distance", "Outward time", "Return time", "Fuel per km", "Round-trip toll"],
          "rows": [
            ["A", "84 km", "70 min", "80 min", "£0.16", "£6"],
            ["B", "72 km", "65 min", "75 min", "£0.18", "£2"],
            ["C", "96 km", "80 min", "85 min", "£0.14", "£0"]
          ]
        }
      ]
    },
    {
      "id": "health-study",
      "title": "Health study participants",
      "content": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "An adverse event count records participants with at least one event during the study." }] },
        {
          "kind": "table",
          "caption": "Twelve-week study outcomes",
          "headers": ["Age group", "Started", "Completed", "Adverse event"],
          "rows": [
            ["18–29", "120", "102", "18"],
            ["30–49", "160", "136", "20"],
            ["50–69", "100", "82", "17"]
          ]
        }
      ]
    }
