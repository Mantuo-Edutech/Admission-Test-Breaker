      "content": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Four trainees — J, K, L and M — each present once from Tuesday to Friday. J presents before L. L presents on Friday. K presents neither Tuesday nor Friday. M presents immediately after K." }] }
      ]
    },
    {
      "id": "programme-outcomes",
      "title": "Training programme outcomes",
      "content": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Costs are total programme costs. Completion rate is completed participants divided by applicants." }] },
        {
          "kind": "table",
          "caption": "Applicants, completions and cost",
          "headers": ["Programme", "Applicants", "Completed", "Total cost"],
          "rows": [
            ["A", "80", "60", "£18,000"],
            ["B", "100", "75", "£30,000"],
            ["C", "60", "54", "£21,600"]
          ]
        }
      ]
    }
