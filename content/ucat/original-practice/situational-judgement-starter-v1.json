  "passages": [
    {
      "id": "record-integrity",
      "title": "An uncertain observation",
      "content": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "During a clinical placement, a student notices that another student entered a patient's observation after the shift from memory. The student who made the entry now says that one value may be incorrect. The supervising clinician is still on the ward." }] }
      ]
    },
    {
      "id": "confidentiality-request",
      "title": "A request from a friend",
      "content": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "A friend messages a student on placement and asks whether a relative has been admitted to the ward. The student has access to the electronic record for placement work but has not been involved in the relative's care." }] }
      ]
    },
    {
      "id": "teamwork-pressure",
      "title": "Repeated lateness",
      "content": [
        { "kind": "paragraph", "runs": [{ "kind": "text", "value": "Two students are delivering patient education sessions together. One has arrived late several times, leaving the other to prepare materials alone. Today's session begins in thirty minutes, and all materials are ready." }] }
      ]
    }
  ],
