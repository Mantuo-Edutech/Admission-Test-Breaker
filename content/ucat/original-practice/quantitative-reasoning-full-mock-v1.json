    { "number": 3, "passageId": "outpatient-clinics", "prompt": "What is the total expected attendance across all four clinics?", "options": ["833", "843", "853", "863"], "correctAnswer": "C", "knowledgeTags": ["ucat-qr-weighted-percentage"], "skillTags": ["aggregate", "multi-row-table"] },
