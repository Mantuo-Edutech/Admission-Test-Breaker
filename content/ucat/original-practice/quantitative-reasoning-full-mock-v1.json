          ["Gloves", "250", "£4.20", "12%", "£25"],
          ["Syringes", "320", "£3.60", "5%", "£35"]
        ]
      }
    },
    {
      "id": "vaccination-programme",
      "title": "Vaccination programme",
      "paragraphs": ["Completed is the number who received every required dose. Percentages should be calculated using the population specified in each question."],
      "table": {
        "caption": "Regional vaccination pathway",
        "headers": ["Region", "Eligible", "Invited", "Attended", "Completed"],
        "rows": [
          ["A", "12,000", "9,000", "7,200", "6,840"],
          ["B", "15,000", "11,200", "8,400", "7,980"],
          ["C", "10,000", "8,000", "6,200", "5,890"],
          ["D", "8,000", "6,400", "5,120", "4,864"]
        ]
      }
    },
    {
      "id": "patient-transport",
      "title": "Patient transport routes",
      "paragraphs": ["Distance is one way. Fuel applies to every kilometre of the round trip, while the toll is paid once for the complete round trip."],
      "table": {
        "caption": "Route distance, time and direct costs",
        "headers": ["Route", "One-way distance", "Outward time", "Return time", "Fuel per km", "Toll", "Driver per hour"],
        "rows": [
          ["A", "75 km", "65 min", "75 min", "£0.18", "£6", "£15"],
          ["B", "92 km", "80 min", "85 min", "£0.16", "£0", "£16"],
          ["C", "68 km", "60 min", "70 min", "£0.20", "£4", "£14"],
          ["D", "105 km", "90 min", "95 min", "£0.14", "£8", "£17"]
        ]
      }
    },
    {
      "id": "trial-retention",
      "title": "Clinical trial retention",
      "paragraphs": ["A response is recorded only for a participant who remained at week 12."],
      "table": {
        "caption": "Participant retention and recorded responses",
        "headers": ["Group", "Started", "Week 4", "Week 12", "Responses at week 12"],
        "rows": [
          ["P", "240", "216", "192", "120"],
          ["Q", "300", "270", "225", "153"],
          ["R", "180", "162", "144", "90"],
          ["S", "280", "238", "196", "119"]
        ]
      }
    },
    {
      "id": "hospital-energy",
      "title": "Hospital energy use",
      "paragraphs": ["Energy figures are measured in kilowatt-hours (kWh). Floor area is unchanged throughout the period."],
      "table": {
        "caption": "Monthly energy use and floor area",
        "headers": ["Department", "January", "February", "March", "Floor area"],
        "rows": [
          ["A", "42,000 kWh", "39,900 kWh", "37,800 kWh", "1,200 m²"],
