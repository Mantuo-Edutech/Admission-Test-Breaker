        ]
      }
    },
    {
      "id": "nutrition-products",
      "title": "Nutrition products",
      "paragraphs": ["Protein is measured in grams per serving and sodium in milligrams per serving. One gram equals 1,000 milligrams."],
      "table": {
        "caption": "Nutrition and pack information",
        "headers": ["Product", "Protein per serving", "Servings per pack", "Pack cost", "Sodium per serving"],
        "rows": [
