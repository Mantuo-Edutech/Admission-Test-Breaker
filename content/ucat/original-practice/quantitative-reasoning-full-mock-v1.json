  "passages": [
    {
      "id": "outpatient-clinics",
      "title": "Outpatient clinics",
      "paragraphs": ["The table shows one day's booked appointments. Treat all percentages as exact and use expected values where necessary."],
      "table": {
        "caption": "Bookings, expected attendance and consultation capacity",
        "headers": ["Clinic", "Booked", "No-show rate", "Consultation", "Rooms"],
        "rows": [
          ["North", "240", "15%", "18 min", "6"],
          ["Central", "300", "8%", "15 min", "8"],
          ["South", "200", "12.5%", "20 min", "5"],
          ["East", "220", "10%", "16 min", "4"]
        ]
      }
    },
    {
      "id": "supply-orders",
      "title": "Medical supply orders",
      "paragraphs": ["The discount applies to the item cost before delivery. Delivery is then added once to each order."],
      "table": {
        "caption": "Order quantities and charges",
        "headers": ["Item", "Quantity", "Unit price", "Discount", "Delivery"],
        "rows": [
