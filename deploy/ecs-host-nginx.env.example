# Browser-safe runtime values for the shared Hong Kong ECS release controller.
# Copy this file outside the repository, chmod 0600, then export the values in
# an approved terminal. Never add service-role, database, SMTP or Turnstile
# secret values here.

APP_IMAGE=ghcr.io/mantuo-edutech/admission-test-breaker:replace-with-40-character-commit-sha
APP_RELEASE=replace-with-40-character-commit-sha
APP_ENVIRONMENT=production
PUBLIC_APP_ORIGIN=https://uktest.cc

SUPABASE_URL=https://replace-with-project-ref.supabase.co
EXPECTED_SUPABASE_PROJECT_REF=replace-with-project-ref
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
TURNSTILE_SITE_KEY=replace-with-public-turnstile-site-key

# These defaults match the existing shared ECS topology. The controller refuses
# ports 80 and 443 and never edits the host Nginx configuration.
DEPLOY_ROOT=/opt/admission-test-breaker
HOST_PORT=8090
NGINX_SITE_CONFIG=/etc/nginx/sites-enabled/admission-test-breaker-preview
APP_CONTAINER_NAME=admission-test-breaker-web
PULL_IMAGE=1
