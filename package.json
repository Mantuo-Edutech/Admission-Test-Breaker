{
  "name": "admission-test-breaker",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 57145",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:architecture": "vitest run tests/architecture/module-boundaries.test.ts",
    "verify:features": "vitest run tests/architecture/feature-manifests.test.ts",
    "verify:supabase-contracts": "vitest run tests/architecture/supabase-contracts.test.ts",
    "verify:supabase": "supabase test db && tsx scripts/verify-supabase-local.ts",
    "verify": "pnpm verify:architecture && pnpm verify:features && pnpm verify:supabase-contracts && pnpm verify:content-imports && pnpm verify:tmua-corpus && pnpm verify:tmua-extractions && pnpm test && pnpm typecheck && pnpm build",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "content:normalize-mineru": "tsx src/content/imports/mineru-cli.ts",
    "verify:content-imports": "vitest run tests/content/imports",
    "tmua:inventory": "tsx src/content/tmua/cli.ts inventory",
    "tmua:sync-official": "tsx src/content/tmua/cli.ts sync-official",
    "tmua:build": "tsx src/content/tmua/cli.ts build",
    "tmua:extract-paper": "tsx src/content/tmua/extract-cli.ts",
    "verify:tmua-files": "tsx src/content/tmua/cli.ts verify-files",
    "verify:tmua-taxonomy": "tsx src/content/tmua/cli.ts verify-taxonomy",
    "verify:tmua-corpus": "tsx src/content/tmua/cli.ts verify-corpus",
    "verify:tmua-extractions": "tsx src/content/tmua/verify-extractions.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@supabase/supabase-js": "^2.110.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "supabase": "^2.109.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
